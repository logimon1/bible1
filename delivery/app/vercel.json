{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/exchange/:booth", "destination": "/index.html" },
    { "source": "/ranking", "destination": "/index.html" },
    { "source": "/team-ranking", "destination": "/index.html" },
    { "source": "/monthly", "destination": "/index.html" },
    { "source": "/forest", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/admin/print/:page", "destination": "/index.html" },
    { "source": "/qr/:code*", "destination": "/index.html" },
    { "source": "/mission/:code*", "destination": "/index.html" },
    { "source": "/hidden/:code*", "destination": "/index.html" },
    { "source": "/boss", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).(css|js|png|jpg|jpeg|webp|svg|woff|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    }
  ]
}
