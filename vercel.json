{
  "rewrites": [
    { "source": "/exchange/:booth", "destination": "/index.html" },
    { "source": "/ranking", "destination": "/index.html" },
    { "source": "/forest", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/qr/:code*", "destination": "/index.html" },
    { "source": "/mission/:code*", "destination": "/index.html" },
    { "source": "/hidden/:code*", "destination": "/index.html" },
    { "source": "/boss", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/app.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/styles.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
