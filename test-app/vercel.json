{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["icn1"],
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/party", "destination": "/index.html" },
    { "source": "/exchange/:booth", "destination": "/index.html" },
    { "source": "/ranking", "destination": "/index.html" },
    { "source": "/forest", "destination": "/index.html" },
    { "source": "/team/:action", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/qr/:code*", "destination": "/index.html" },
    { "source": "/draw/:count", "destination": "/index.html" },
    { "source": "/mission/:code*", "destination": "/index.html" },
    { "source": "/hidden/:code*", "destination": "/index.html" },
    { "source": "/boss", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    { "source": "/", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
    { "source": "/party", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
    { "source": "/ranking", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
    { "source": "/forest", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
    { "source": "/admin", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
    { "source": "/boss", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
    { "source": "/team/:action", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
    { "source": "/exchange/:booth", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
    { "source": "/qr/:code*", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
    { "source": "/draw/:count", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
    { "source": "/mission/:code*", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
    { "source": "/hidden/:code*", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
    { "source": "/index.html", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
    { "source": "/app.js", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
    { "source": "/styles.css", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] }
  ]
}
